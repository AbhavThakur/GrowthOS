# Growth OS — Environment Variables
# Copy this file to .env.local and fill in values
# ALL variables are OPTIONAL — app works fully on localStorage without them

# ── Firebase (optional — only needed if you add Firestore sync later) ──
# Create a project at https://console.firebase.google.com
# Project Settings → General → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional comma-separated allowlist for Firebase Auth users.
# Leave blank for local development; set in Vercel for private access.
VITE_ALLOWED_AUTH_EMAILS=

# Render/Railway career worker API, e.g. https://growthos-career-worker.onrender.com
VITE_CAREER_API_BASE_URL=

# ── Gemini AI (optional — AILab falls back to mock mode without this) ──
# Get a key at https://aistudio.google.com/app/apikey (free tier available)
VITE_GEMINI_KEY=
